# ============================================
# FlashRV Backend - Environment Variables
# ============================================
# Copy this file to .env and fill with real values

# Server
PORT=4000
NODE_ENV=development

# Database
# Dev: DATABASE_URL="file:./dev.db"
# Prod: DATABASE_URL="postgresql://user:pass@host:5432/flashrv?schema=public"
DATABASE_URL="file:./dev.db"

# JWT - IMPORTANT: use a strong secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=change_me_to_a_strong_random_string
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Public frontend base URL (used for payment return URLs)
BASE_URL=http://localhost:3000
# Backend public URL (used for payment callbacks/IPN)
API_URL=http://localhost:4000
# For production, set comma-separated allowed origins:
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# PayDunya
PAYDUNYA_MASTER_KEY=your_master_key
PAYDUNYA_PUBLIC_KEY=your_public_key
PAYDUNYA_PRIVATE_KEY=your_private_key
PAYDUNYA_TOKEN=your_token
PAYDUNYA_MODE=test
PAYDUNYA_STORE_NAME=StyleFlow
PAYDUNYA_STORE_TAGLINE=Paiement securise des reservations
PAYDUNYA_STORE_PHONE=
PAYDUNYA_STORE_ADDRESS=

# OpenAI Assistant (optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Web Push (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_MAILTO=mailto:contact@styleflow.me
