# ============================================
# FlashRV Backend - Environment Variables
# ============================================
# Copy this file to .env and fill with real values

# Server
PORT=4000
NODE_ENV=development

# Database
# Dev: DATABASE_URL="file:./dev.db"
# Prod: DATABASE_URL="postgresql://user:pass@host:5432/flashrv?schema=public"
DATABASE_URL="file:./dev.db"

# JWT - IMPORTANT: use a strong secret in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=change_me_to_a_strong_random_string
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# For production, set comma-separated allowed origins:
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# OpenAI Assistant (optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
