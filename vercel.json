{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets|favicon|icons|manifest\\.json|sw\\.js|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
