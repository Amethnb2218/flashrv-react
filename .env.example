# FlashRV Frontend Environment Variables
# Copy to .env.local and fill in values

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# API URL - only needed if backend is on a different domain
# In development, Vite proxy handles /api routes automatically
# In production, set to your backend URL:
# VITE_API_URL=https://api.your-domain.com/api

# Optional: request timeout for API calls (milliseconds)
# VITE_API_TIMEOUT_MS=15000

# Optional: disable auto push subscription attempts if backend push is unavailable
# VITE_ENABLE_PUSH_SUBSCRIPTION=true
